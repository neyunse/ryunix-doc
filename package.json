{
  "name": "ryunix-doc",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "homepage": "./",
  "scripts": {
    "clean": "rm -rf .ryunix react-doctor-mirror",
    "doctor": "node scripts/sync-react-doctor-mirror.mjs && react-doctor . --no-dead-code",
    "doctor:verbose": "node scripts/sync-react-doctor-mirror.mjs && react-doctor . --no-dead-code --verbose",
    "doctor:diff": "node scripts/sync-react-doctor-mirror.mjs && react-doctor . --no-dead-code --diff",
    "doctor:dead-code": "react-doctor . --verbose",
    "dev": "ryunix dev",
    "start": "ryunix start",
    "build": "ryunix build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@unsetsoft/ryunixjs": "workspace:*",
    "clsx": "^2.1.1",
    "lucide": "^0.575.0",
    "tailwind-merge": "^3.6.0"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": "^20 || ^22 || ^24 || ^26"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "8.50.0",
    "@unsetsoft/ryunix-presets": "workspace:*",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.3",
    "highlight.js": "11.11.1",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-doctor": "^0.2.10",
    "tailwindcss": "^4.3.0",
    "typescript": "5.9.3"
  }
}
