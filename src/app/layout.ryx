import "@/styles/global.css";
import { headerScrollScript } from "@/components/layout/header/headerScrollScript";
import { themeInitScript } from "@/i18n/themeCookie";

import type { RyunixNode } from "@unsetsoft/ryunixjs";

const RootLayout = ({ children }: { children?: RyunixNode }) => {
  const bootScripts = `${themeInitScript}\n${headerScrollScript}`;

  return (
    <>
      <script dangerouslySetInnerHTML={{ __html: bootScripts }} />
      {children}
    </>
  );
};

export default RootLayout;
