import { docSlugs } from "@/i18n/docSlugs.js";
import DocMdxCatchAll from "@/features/docs/DocMdxCatchAll.ryx";

export const generateStaticParams = () =>
  docSlugs.map((slug) => ({
    slug: slug.split("/"),
  }));

const LocalizedDocPage = ({ params }) => <DocMdxCatchAll params={params} />;

export default LocalizedDocPage;
