import LocaleDocLayout from "@/features/docs/LocaleDocLayout.ryx";
import { localeDocMeta } from "@/i18n/localeDocMeta.js";

export const generateMetadata = async ({ params }) => {
  const locale = params?.locale === "es" ? "es" : "en";
  return localeDocMeta[locale] ?? localeDocMeta.en;
};

const DocLayout = ({ children, params }) => {
  const locale = params?.locale === "es" ? "es" : "en";
  return <LocaleDocLayout locale={locale}>{children}</LocaleDocLayout>;
};

export default DocLayout;
