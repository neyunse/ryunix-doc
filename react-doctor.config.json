{
  "$schema": "https://react.doctor/schema.json",
  "adoptExistingLintConfig": false,
  "deadCode": true,
  "ignore": {
    "files": [
      "src/content/**",
      ".ryunix/**",
      "middleware.ts",
      "ryunix.config.ts"
    ],
    "rules": ["deslop/unused-dev-dependency"],
    "overrides": [
      {
        "files": ["react-doctor-mirror/**"],
        "rules": [
          "react-doctor/exhaustive-deps",
          "react-hooks/exhaustive-deps"
        ]
      }
    ]
  },
  "surfaces": {
    "ciFailure": {
      "excludeTags": ["design"]
    }
  }
}
